    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^5.0.0",
    "googleapis": "^171.4.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  }
