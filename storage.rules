rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Video uploads — authenticated users can read/write to their own folder
    match /videos/{keeperId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == keeperId || request.auth.token.email == 'evan@tacanni.com');
      allow write: if request.auth != null && (request.auth.uid == keeperId || request.auth.token.email == 'evan@tacanni.com');
      allow delete: if request.auth != null && (request.auth.uid == keeperId || request.auth.token.email == 'evan@tacanni.com');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
