[debug] [2026-03-29T16:16:04.325Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/goalie-coach-dev-11a17/rulesets {"name":"projects/goalie-coach-dev-11a17/rulesets/45673f63-efd5-4100-b821-5bacc63e28aa","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // ============================================================\n    // HELPER FUNCTIONS\n    // ============================================================\n\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    function isOwner(uid) {\n      return isAuthenticated() && request.auth.uid == uid;\n    }\n\n    function isAdmin() {\n      return isAuthenticated() && request.auth.token.email == 'evan@tacanni.com';\n    }\n\n    // ============================================================\n    // USER PROFILES\n    // ============================================================\n\n    match /users/{uid} {\n      allow read: if isOwner(uid) || isAdmin();\n      allow list: if isAdmin();\n      allow create: if isOwner(uid);\n      allow update: if isOwner(uid) || isAdmin();\n      allow delete: if false; // Cloud Function only\n\n      // --------------------------------------------------------\n      // VIDEO SESSIONS (Web Dashboard uploads)\n      // --------------------------------------------------------\n      match /sessions/{sessionId} {\n        allow read, write: if isOwner(uid) || isAdmin();\n      }\n    }\n\n    // ============================================================\n    // PROMO CODES\n    // ============================================================\n\n    match /promoCodes/{codeId} {\n      // Any authenticated user may read a code by ID (needed for redemption checks)\n      allow read: if isAuthenticated();\n      // Only admin can create or update codes\n      allow create, update: if isAdmin();\n      allow delete: if false;\n\n      match /redemptions/{uid} {\n        // Users can see their own redemption record\n        allow read: if isOwner(uid);\n        // Writes are Cloud Function only (service account bypasses rules)\n        allow write: if false;\n      }\n    }\n\n    // ============================================================\n    // SHARED REPORTS\n    // ============================================================\n\n    match /sharedReports/{reportId} {\n      allow read: if request.time < resource.data.expiresAt;\n      allow write: if false; // Only Cloud Functions can create them\n    }\n\n    // ============================================================\n    // TED CONVERSATIONS\n    // ============================================================\n    \n    match /tedConversations/{chatId} {\n      // Anyone (even anonymous) can create a chat log\n      allow create: if true;\n      // Only admin can read or manage these logs\n      allow read, update, delete: if isAdmin();\n    }\n\n    // ============================================================\n    // CATCH-ALL\n    // ============================================================\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-29T16:16:04.314447Z","metadata":{"services":["cloud.firestore"]}}
